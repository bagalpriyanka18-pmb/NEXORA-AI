body{
    margin:0;
    padding:0;
    font-family:Arial, sans-serif;
    background:#f4f6f9;
}

.container{

    width:400px;

    margin:150px auto;

    background:white;

    padding:30px;

    text-align:center;

    border-radius:10px;

    box-shadow:0 0 10px lightgray;
}

h1{

    color:#1f4bd8;
}

p{

    color:gray;
}

input{

    width:90%;

    padding:10px;

    border:1px solid gray;

    border-radius:5px;
}

button{

    padding:10px 25px;

    background:#1f4bd8;

    color:white;

    border:none;

    border-radius:5px;

    cursor:pointer;
}

button:hover{

    background:#1436a5;
}
nav{
   
    background:#1f4bd8;
    color:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 40px;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    z-index:1000;
    box-sizing:border-box;

}

nav h2{
    margin:0;
}

nav ul{
    list-style:none;
    display:flex;
    gap:20px;
    margin:0;
    padding:0;
}

nav li{
    cursor:pointer;
}
body{
    margin:0;
    padding:0;
    font-family:Arial, sans-serif;
    background:#f4f6f9;
}

nav{
    background:#1f4bd8;
    color:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 40px;
}

nav h2{
    margin:0;
}

nav ul{
    list-style:none;
    display:flex;
    gap:20px;
    margin:0;
    padding:0;
}

.container{
    width:500px;
    margin:60px auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 0 15px lightgray;
    text-align:center;
}

h1{
    color:#1f4bd8;
}

h3{
    color:#444;
}

p{
    color:#666;
}

input{
    width:90%;
    padding:12px;
    border:1px solid #ccc;
    border-radius:5px;
    font-size:16px;
}

button{
    padding:12px 30px;
    background:#1f4bd8;
    color:white;
    border:none;
    border-radius:5px;
    cursor:pointer;
    font-size:16px;
}

button:hover{
    background:#1436a5;
}

hr{
    margin:25px 0;
}
.container ul{
    list-style: none;
    padding: 0;
}

.container li{
    margin: 10px 0;
    font-size: 18px;
}
.container h2{
    color:#0b5ed7;
    margin-top:30px;
}

.container ul{
    list-style:none;
    padding-left:0;
}

.container li{
    font-size:18px;
    padding:8px;
    border-bottom:1px solid #ddd;
}